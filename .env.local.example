# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit real secrets.

# OpenAI – used for the single summary + sentiment call (model: gpt-4o-mini).
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GNews – used to search for news articles. Free tier: 100 requests/day.
# Sign up at https://gnews.io/
GNEWS_API_KEY=

# MongoDB connection string. Use a free MongoDB Atlas cluster:
# https://www.mongodb.com/cloud/atlas/register
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name to use inside the cluster.
MONGODB_DB=smart_reviewer
